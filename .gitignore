Firmware-Merged/
.claude/

# =============================================================================
# ODrive Python tooling (unused — our HTML config tool replaces it)
# Has Git LFS binaries (libfibre.dll etc) that fail to push without LFS server
# =============================================================================
ODrive-fw-v0.5.6/ODrive-fw-v0.5.6/Firmware/fibre-cpp/test/
ODrive-fw-v0.5.6/ODrive-fw-v0.5.6/.gitattributes
ODrive-fw-v0.5.6/ODrive-fw-v0.5.6/Firmware/.gitattributes

# =============================================================================
# Allow CMSIS DSP libs (required for linking)
# =============================================================================
!ODrive-fw-v0.5.6/ODrive-fw-v0.5.6/Firmware/ThirdParty/CMSIS/Lib/GCC/libarm_cortexM4lf_math.a
!ODrive-fw-v0.5.6/ODrive-fw-v0.5.6/Firmware/ThirdParty/CMSIS/Lib/GCC/libarm_cortexM7lfsp_math.a

# =============================================================================
# ODrive upstream tools/ — só rastreamos os 2 scripts que o build precisa
# (version.py + interface_generator.py via PR #1). O resto do diretório é
# ferramenta Python CLI do upstream (odrivetool, dfu.py, etc) que não usamos
# porque nosso HTML config tool substitui essa stack.
# =============================================================================
ODrive-fw-v0.5.6/ODrive-fw-v0.5.6/tools/**
!ODrive-fw-v0.5.6/ODrive-fw-v0.5.6/tools/odrive/
!ODrive-fw-v0.5.6/ODrive-fw-v0.5.6/tools/odrive/version.py
!ODrive-fw-v0.5.6/ODrive-fw-v0.5.6/tools/fibre-tools/
!ODrive-fw-v0.5.6/ODrive-fw-v0.5.6/tools/fibre-tools/interface_generator.py
